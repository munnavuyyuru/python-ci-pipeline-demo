[flake8]
# Maximum line length
max-line-length = 88

# Extend default ignore list
extend-ignore =
    E203,
    E501,
    W503,
    E402,
    F401,

# Exclude directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .coverage,
    htmlcov

# Maximum complexity
max-complexity = 10

# Show source code for errors
show-source = true

# Show statistics
statistics = true

# Count errors and warnings
count = true
